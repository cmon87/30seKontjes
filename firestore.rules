rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "simon.reede@gmail.com"
        && request.auth.token.email_verified == true;
    }
    match /rooms/{roomCode} {
      function isMember() {
        return signedIn()
          && resource.data.spelers[request.auth.uid] != null;
      }
      function joinsSelf() {
        return signedIn()
          && resource.data.meta.status == "LOBBY"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["spelers"])
          && request.resource.data.spelers[request.auth.uid] != null;
      }
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || isMember() || joinsSelf();
      allow delete: if isAdmin();
    }
  }
}
