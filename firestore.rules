rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      function signedIn() { return request.auth != null; }
      function isMember() { return signedIn() && resource.data.spelers[request.auth.uid] != null; }
      function joinsSelf() {
        return signedIn()
          && resource.data.meta.status == "LOBBY"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["spelers"])
          && request.resource.data.spelers[request.auth.uid] != null;
      }
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.meta.hostId == request.auth.uid
        && request.resource.data.spelers[request.auth.uid] != null;
      allow update: if isMember() || joinsSelf();
      allow delete: if signedIn() && resource.data.meta.hostId == request.auth.uid;
    }
  }
}
